{
  "name": "tealus-rtc-server",
  "version": "0.1.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "description": "Tealus RTC Server — mediasoup SFU for voice/video calls and transceiver",
  "license": "MIT",
  "main": "server.js",
  "scripts": {
    "build": "esbuild src/client.js --bundle --outfile=public/bundle.js --format=iife --platform=browser",
    "postinstall": "npm run build",
    "start": "node server.js",
    "dev": "npm run build && node server.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "mediasoup": "^3.19.19",
    "mediasoup-client": "^3.18.7",
    "socket.io-client": "^4.8.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0"
  }
}
