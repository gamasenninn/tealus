# ========================================
# Tealus RTC Server — Environment Variables
# ========================================
# Copy this file to `.env` and fill in your values.

# ---- Server ----
RTC_PORT=3100
RTC_HOST=0.0.0.0

# ---- mediasoup network ----
# The IP announced to WebRTC clients. For LAN use your server's LAN IP.
# For localhost testing, 127.0.0.1 is fine.
ANNOUNCED_IP=127.0.0.1
# Public IP (used when behind NAT). Leave blank for localhost/LAN.
PUBLIC_IP=

# ---- JWT (must match tealus server) ----
JWT_SECRET=

# ---- Tealus API (for Bot-driven RTC reader) ----
TEALUS_API_URL=http://localhost:3000

# ---- Aivis TTS (optional, for TTS reader bot) ----
AIVIS_API_KEY=
AIVIS_MODEL_UUID=f5017410-fbb5-49e1-97cb-e785f42e15f5

# ---- TTS reader bot (optional) ----
# TTS_READER_BOT_ID=
# TTS_READER_BOT_PASS=
# TTS_READER_ROOMS=              # comma-separated room IDs
# TTS_READER_WATCH=false
# TTS_READER_MAX_LENGTH=500
