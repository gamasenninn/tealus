# ========================================
# Tealus Agent Server — Environment Variables
# ========================================
# Copy this file to `.env` and fill in your values.

# ---- Server ----
AGENT_PORT=4000
NODE_ENV=development

# ---- Tealus API ----
# Tealus Server base URL and the Bot user account that the agent logs in as
TEALUS_API_URL=http://localhost:3000
TEALUS_BOT_ID=AI_AGENT
TEALUS_BOT_PASS=your_bot_password

# ---- JWT (must match tealus server) ----
# REQUIRED in production. Must be identical to Tealus Server JWT_SECRET.
JWT_SECRET=

# ---- Database (PostgreSQL) ----
# Used by the agent's session manager. Either DATABASE_URL or individual DB_* vars.
# DATABASE_URL=postgresql://tealus:password@localhost:5432/tealus
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tealus
DB_USER=tealus
DB_PASSWORD=change_this_password

# ---- OpenAI ----
OPENAI_API_KEY=
AGENT_LIGHT_MODEL=gpt-4o-mini
AGENT_ROUTER_MODEL=gpt-4o-mini

# ---- Tavily (web search MCP) ----
# Configured via agent-server/mcp_config.json, not here.

# ---- Workspace ----
AGENT_WORKSPACE_ROOT=./agent-workspaces

# ---- Webhook ----
WEBHOOK_SECRET=

# ---- Deep agent limits ----
DEEP_TIMEOUT=300000            # milliseconds
DEEP_MAX_BUFFER=10485760       # bytes (10 MiB)
LIGHT_CONTEXT_MESSAGES=20

# ---- MCP cache ----
# MCP_CACHE_TTL=600000         # milliseconds
# MCP_SWEEP_INTERVAL=60000     # milliseconds

# ---- RTC proxy ----
RTC_PORT=3100

# ---- Aivis Cloud TTS ----
# Set AIVIS_API_KEY to enable text-to-speech read-aloud in DMs/rooms.
# Get an API key at https://aivis-project.com
AIVIS_API_KEY=
# Default voice model UUID (Rinne Ell). Override per-room via dashboard settings.
AIVIS_MODEL_UUID=f5017410-fbb5-49e1-97cb-e785f42e15f5
TTS_ENABLED=true
TTS_MAX_LENGTH=500
