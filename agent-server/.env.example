# ========================================
# Tealus Agent Server — Environment Variables
# ========================================
# Copy this file to `.env` and fill in your values.

# ---- Server ----
AGENT_PORT=4000
NODE_ENV=development

# ---- Tealus API ----
# Tealus Server base URL and the Bot user account that the agent logs in as
TEALUS_API_URL=http://localhost:3000
TEALUS_BOT_ID=AI_AGENT
TEALUS_BOT_PASS=your_bot_password

# ---- JWT (must match tealus server) ----
# REQUIRED in production. Must be identical to Tealus Server JWT_SECRET.
JWT_SECRET=

# ---- Database (PostgreSQL) ----
# Used by the agent's session manager. Either DATABASE_URL or individual DB_* vars.
# DATABASE_URL=postgresql://tealus:password@localhost:5432/tealus
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tealus
DB_USER=tealus
DB_PASSWORD=change_this_password

# ---- OpenAI ----
OPENAI_API_KEY=
# Light v2 (#258、`/light2` prefix) は @openai/codex-sdk が同 OPENAI_API_KEY を
# 内部で使うため追加 env 不要。`codex login` (interactive auth) も不要、
# SDK が apiKey option 経由で auth する。

# AGENT_LIGHT_MODEL: Light agent (multi-step reasoning + tool use) のモデル
#   gpt-5.4-mini  — 推奨 (#229 で実機 verified、画像 / PDF 両対応、月 $25-225 想定)
#   gpt-4o-mini   — cost-effective、ただし PDF 等で training bias で「自分は読めない」と
#                   先回り判断して tool 呼ばないケースあり (画像認識は OK、月 $5-30 想定)
# 質優先なら gpt-5.4-mini、cost 優先なら gpt-4o-mini。env で切替可能。
AGENT_LIGHT_MODEL=gpt-5.4-mini

# AGENT_ROUTER_MODEL: Router (light/deep 振分) は cost-sensitive (毎 message)
#   gpt-4o-mini  — 推奨 (簡単な振分なので軽量モデルで十分)
AGENT_ROUTER_MODEL=gpt-4o-mini

# ---- Tavily (web search MCP) ----
# Configured via agent-server/mcp_config.json, not here.

# ---- Gemini (PDF/image vision fallback for tealus-mcp read_document、#233) ----
# tealus-mcp v0.9.0+ の read_document tool が scan PDF / image-only PDF を検出した時、
# Gemini API multimodal で text 化して返す fallback layer。
# unset で disable (default)、設定すると自動 enable。
#
# **Privacy 注意**: Gemini free tier は Google が製品改善のため input/output を利用、
# human reviewer が処理する可能性あり (https://ai.google.dev/gemini-api/terms 参照)。
# 社内文書を扱う場合は paid billing account に紐付けた key の使用を推奨。
#
# 無料枠: gemini-2.5-flash-lite で 1,000 RPD / 15 RPM (2026-05 時点)
GOOGLE_API_KEY=

# DOCUMENT_VISION_PROVIDER: 'gemini' (default if GOOGLE_API_KEY set) | 'none' (disable)
# DOCUMENT_VISION_MODEL: default 'gemini-2.5-flash-lite' (無料枠で最 generous)
# DOCUMENT_VISION_MAX_PAGES: default 20 (cost 保護、超過時 vision skip)
# DOCUMENT_VISION_PROVIDER=gemini
# DOCUMENT_VISION_MODEL=gemini-2.5-flash-lite
# DOCUMENT_VISION_MAX_PAGES=20

# ---- Workspace ----
AGENT_WORKSPACE_ROOT=./agent-workspaces

# ---- Webhook ----
WEBHOOK_SECRET=

# ---- Deep agent limits ----
DEEP_TIMEOUT=300000            # milliseconds
DEEP_MAX_BUFFER=10485760       # bytes (10 MiB)
LIGHT_CONTEXT_MESSAGES=20

# ---- MCP cache ----
# MCP_CACHE_TTL=600000         # milliseconds
# MCP_SWEEP_INTERVAL=60000     # milliseconds

# ---- RTC proxy ----
RTC_PORT=3100

# ---- TTS Provider ----
# AI 応答の音声合成方式を選択する。ここが TTS_PROVIDER の真の情報源。
# client は起動時に GET /api/config (server) → /public-config (agent-server) で取得する。
# 設定変更は server / agent-server の再起動のみで反映（client 再ビルド不要）。
# 値: browser | aivis-cloud | none
#   browser     — クライアント端末の Web Speech API で合成（API key 不要、ゼロ設定）
#   aivis-cloud — Aivis Cloud API + mediasoup で配信（高品質、API key 必須）
#   none        — TTS 完全無効
# 未設定時は AIVIS_API_KEY の有無で自動判定:
#   AIVIS_API_KEY 設定あり → aivis-cloud
#   AIVIS_API_KEY 未設定   → browser
# 明示制御するなら下の行を有効化
# TTS_PROVIDER=browser

# ---- Aivis Cloud TTS（TTS_PROVIDER=aivis-cloud の場合に必要）----
# Set AIVIS_API_KEY to enable text-to-speech read-aloud in DMs/rooms.
# Get an API key at https://aivis-project.com
AIVIS_API_KEY=
# Default voice model UUID (Rinne Ell). Override per-room via dashboard settings.
AIVIS_MODEL_UUID=f5017410-fbb5-49e1-97cb-e785f42e15f5
TTS_ENABLED=true
TTS_MAX_LENGTH=500

# ---- cc-queue (Claude Code routing、#213 → #215 で primary defense 変更) ----
# #215 (2026-05-02) 以降、cc-tealus は @cc-{project} がメッセージの先頭に
# あるときだけ match する仕様になったため、self-loop 防止には
# CC_SKIP_SENDER_IDS は **基本不要**。AI reply は本文中で mention を引用しても
# 先頭にないため、自然に skip される。
#
# 以下は defense in depth として任意で設定可能 (Phase A 初期実装の名残)。
# 特殊な edge case (AI reply の本文が `@cc-foo` で始まる等) で self-loop が
# 発生する場合のみ、cc bot user の UUID を CSV で列挙する。
# CC_SKIP_SENDER_IDS=b3e292d6-1953-4389-9fba-7e56421a2aef,another-uuid

# ---- TTS broadcast via mediasoup (legacy 互換、#189) ----
# Aivis Cloud TTS の配信は default で server 経由 Socket.IO blob (rtc-server 不要)。
# transceiver gateway 受信機 (mediasoup PlainTransport を listen する専用 hardware) を
# 運用している環境では、true にすると Socket.IO 配信に **加えて** mediasoup でも broadcast。
# 注意: browser client が transceiver active 状態のときは両方から受信して二重再生になる。
# default false。
# TTS_BROADCAST_MEDIASOUP=true
