# ========================================
# Tealus Client — Environment Variables
# ========================================
# Copy this file to `.env` and fill in your values.
# Only VITE_-prefixed variables are exposed to the browser.

# ---- Web Push (VAPID public key) ----
# Must match server/.env VAPID_PUBLIC_KEY.
# Generate with: `npx web-push generate-vapid-keys`
VITE_VAPID_PUBLIC_KEY=

# ---- TTS Provider ----
# AI 音声応答の合成方式。agent-server/.env の TTS_PROVIDER と同じ値にする。
# 値: browser (デフォルト推奨) | aivis-cloud | none
#   browser     — Web Speech API で各端末ローカル合成（API key 不要）
#   aivis-cloud — Aivis Cloud + mediasoup（高品質、API key 必須）
#   none        — TTS 完全無効
# 未設定時は 'browser' として扱われる
VITE_TTS_PROVIDER=browser
