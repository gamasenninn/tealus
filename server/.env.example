# ========================================
# Tealus Server — Environment Variables
# ========================================
# Copy this file to `.env` and fill in your values.

# ---- Server ----
PORT=3000
NODE_ENV=development          # development | production | test
LOG_LEVEL=debug               # debug | info | warn | error

# ---- Database (PostgreSQL) ----
# 以下の値は docker-compose.yml のデフォルトと一致している（そのまま dev 起動可）
# 本番では別の強力なパスワードに変更し、docker-compose も合わせて更新すること。
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tealus
DB_USER=tealus
DB_PASSWORD=tealus_dev

# ---- JWT Authentication ----
# REQUIRED in production. Generate with: `openssl rand -hex 32`
# If NODE_ENV=production and this is unset, the server will refuse to start.
#
# **共有要件**: agent-server (`agent-server/.env`) および tealus-mcp (HTTP transport
# 起動時、`--transport=http`) と **完全に同じ値** にすること。proxy で pass-through、
# 検証は各 target server 側で独立に実施 (fail-fast 401)。
JWT_SECRET=

# ---- Media Storage ----
# Relative to server/ or absolute path
MEDIA_ROOT=../media

# ---- Internal service proxy (same-host) ----
AGENT_PORT=4000
RTC_PORT=3100
# tealus-mcp HTTP transport の listen port (#264 Phase 1 alpha)
# tealus-mcp を `--transport=http` で起動した時にここに forward される
# (server.js が /mcp/* を `localhost:${MCP_HTTP_PORT}` に proxy)
MCP_HTTP_PORT=3200

# ---- OpenAI (used for voice transcription / AI formatting) ----
# Optional: if unset, voice transcription/formatting is disabled
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
# WHISPER_MODEL の選択肢 (#217 で gpt-4o-transcribe を default 採用):
#   gpt-4o-transcribe       — 新世代、hallucination 軽減 (推奨 default、~$0.006/分相当)
#   gpt-4o-mini-transcribe  — 軽量版 (~$0.003/分相当、whisper-1 比 約半額)
#   whisper-1               — 旧 default ($0.006/分、無音→TV ノイズ捏造の傾向あり)
#
# 用途別推奨 (5/12 dogfood 確定):
#   業務無線 / 一般用途 → gpt-4o-mini-transcribe (推奨 default、辞書 prompt 効果完璧確認済)
#   議事録 / 精度最優先 → gpt-4o-transcribe (兄弟モデル、辞書 prompt も default 有効)
#   legacy whisper-1   → vocab inject 無効 (bias 観測 history あり、新規採用非推奨)
#
# #269 Phase 2 (5/12 実装): 新世代 transcribe model に WHISPER_MODEL を設定すると
# transcription_guideline.json の vocabulary が Whisper prompt に自動 inject。
# 5/12 dogfood: 6/6 完璧 (グレンコンテナ / マニアスプレッダ / ハーベスタ / みこがい 等
# 業界用語と短人名すべて正確、control 文も clean、副作用なし)
WHISPER_MODEL=gpt-4o-mini-transcribe

# Optional: vocabulary を Whisper prompt に inject する model の list (#269 Phase 2)。
# default: 'gpt-4o-mini-transcribe,gpt-4o-transcribe' (新世代 transcribe 兄弟 2 model)。
# whisper-1 は default で除外 (legacy bias 観測あり)。
# 議事録 use case で vocab inject を opt-out したい場合: 'gpt-4o-mini-transcribe' に絞る。
# WHISPER_VOCAB_INJECT_MODELS=
# Optional: 組織固有 vocabulary + guidelines を JSON で注入する設定ファイルのパス。
# 未指定時のデフォルトは server/config/transcription_guideline.json (gitignored)。
# サンプル: server/config/transcription_guideline.example.json
# TRANSCRIPTION_GUIDELINE_PATH=

# ---- Web Push (VAPID keys) ----
# Generate with: `npx web-push generate-vapid-keys`
# client は GET /api/config 経由で VAPID_PUBLIC_KEY を取得する（client 再ビルド不要）。
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ---- Stamp image generation (optional) ----
# STAMP_TEXT_API_KEY / STAMP_IMAGE_API_KEY を未指定にすると OPENAI_API_KEY に
# フォールバック (#221)。1 つの OpenAI key で stamp も assistant も動く。
# 別 provider (将来 Stable Diffusion 等) を使う採用者は STAMP_*_API_KEY を明示
# すれば override 可能。
# STAMP_TEXT_PROVIDER=openai
# STAMP_TEXT_API_KEY=
# STAMP_TEXT_MODEL=gpt-4o-mini
# STAMP_IMAGE_PROVIDER=openai
# STAMP_IMAGE_API_KEY=
# STAMP_IMAGE_MODEL=dall-e-3

# ---- LINE Bridge Phase 1 (= Inbound 受信のみ、text + 画像 + 音声) ----
# LINE Developers console で bot を作成 → 以下 4 値を設定 → server 再起動
# Inbound only (= LINE → Tealus)、双方向しない (= LINE outbound API 高額のため scope 外)
# LINE 音声 → Tealus voice post → 既存 Whisper 文字起こし + organon polyseme inject 自動連動

# 署名 verify 用 (= LINE Developers console の Basic settings)
# LINE_CHANNEL_SECRET=

# Content API (= 画像/音声 binary fetch) 用 (= LINE Developers console の Messaging API)
# LINE_CHANNEL_ACCESS_TOKEN=

# webhook secret path (= 隠し URL の一部、推測困難な random 文字列推奨、最終 URL = /api/line/webhook/<this>)
# LINE_WEBHOOK_SECRET_PATH=

# Tealus 内 LINE bot user の uuid (= 事前に INSERT INTO users (is_bot=true)、投稿者として表示)
# 対象 Tealus room の room_members に同 user を add 必須 (= LINE 由来 message 投稿時の DB 制約)
# LINE_BOT_USER_ID=

# LINE グループ ID → Tealus ルーム ID mapping (= JSON、未登録グループは silent skip)
# 例: LINE_GROUP_TO_ROOM='{"Cabcd1234":"<tealus-room-uuid>"}'
# LINE_GROUP_TO_ROOM={}
