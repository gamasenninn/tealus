{
  "name": "tealus-server",
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "description": "Tealus - Server",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "dev:demo": "node --env-file=.env.demo src/app.js",
    "migrate:demo": "node --env-file=.env.demo src/db/migrate.js",
    "seed:demo": "node --env-file=.env.demo scripts/seed-demo.js --confirm",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --runInBand --watch",
    "migrate": "node src/db/migrate.js",
    "license-check": "npx license-checker-rseidelsohn --production --excludePrivatePackages --summary",
    "license-fail-on-gpl": "npx license-checker-rseidelsohn --production --excludePrivatePackages --failOn 'GPL;AGPL-1.0;AGPL-3.0'"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "file-type": "^22.0.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0"
  }
}
